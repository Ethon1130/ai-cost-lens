# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# build info
*.tsbuildinfo
next-env.d.ts

# logs (runtime + dev server + temp)
/*.log
/*.err
/logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.tmp-*.log
.tmp-*.err
/tmp-*.log
/tmp-*.err

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# turbo / turbopack
.turbo

# editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# misc
*.pem
*.pid
*.seed
*.pid.lock

# local scratch / downloaded archives / random tooling
/SoftwareCopyright-Skill-main
/SoftwareCopyright-Skill-main/
# One-off downloaded business docs that should never be committed.
/*软著*/
# Catch-all for any other top-level Chinese-named scratch folder.
/*?*/
